# Use the Prisma Postgres integration from Vercel Marketeplace to automatically connect a Prisma Postgres instance
# Or manually run `npx prisma init --db` to create a Prisma Postgres and manually set the `DATABASE_URL` below
DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=PRISMA_POSTGRES_API_KEY"
POSTGRES_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=PRISMA_POSTGRES_API_KEY"
PRISMA_DATABASE_URL="prisma+postgres://accelerate.prisma-data.net/?api_key=PRISMA_POSTGRES_API_KEY"

# Create a random 32-character string or run `npx auth secret` to obtain one and set it as the `AUTH_SECRET` below
NEXTAUTH_SECRET="RANDOM_32_CHARACTER_STRING"

# Public URL of your app used in password reset links
APP_BASE_URL="http://localhost:3000"

# SMTP configuration for password reset emails
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="smtp_username"
SMTP_PASS="smtp_password"
MAIL_FROM="STB Booking <noreply@example.com>"